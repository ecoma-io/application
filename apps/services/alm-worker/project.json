{
  "name": "alm-worker",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/services/alm-worker/src",
  "projectType": "application",
  "tags": ["type:app", "bc:alm"],
  "implicitDependencies": [
    "alm-domain",
    "alm-application",
    "alm-infrastructure",
    "common-infrastructure",
    "common-application",
    "common-domain",
    "common-types",
    "common-utils"
  ],
  "targets": {
    "compile": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/services/alm-worker",
        "command": "webpack-cli build",
        "args": ["node-env=production"]
      },
      "configurations": {
        "development": {
          "args": ["node-env=development"]
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["compile"],
      "options": {
        "inspect": false,
        "buildTarget": "alm-worker:compile",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "alm-worker:compile:development"
        },
        "production": {
          "buildTarget": "alm-worker:compile:production"
        }
      }
    },
    "build": {
      "dependsOn": ["compile"],
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "load": true,
        "quiet": true,
        "target": "debug",
        "tags": ["ghcr.io/ecoma-io/alm-worker:latest"]
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "INPUT_TARGET=distroless INPUT_TAGS=ghcr.io/ecoma-io/alm-worker:$VERSION npx nx build alm-worker --push"
      }
    }
  }
}
