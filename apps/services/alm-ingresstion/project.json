{
  "name": "alm-ingresstion",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/services/alm-ingresstion/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "compile": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["node-env=production"]
      },
      "configurations": {
        "development": {
          "args": ["node-env=development"]
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["compile"],
      "options": {
        "buildTarget": "alm-ingresstion:compile",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "alm-ingresstion:compile:development"
        },
        "production": {
          "buildTarget": "alm-ingresstion:compile:production"
        }
      }
    },
    "build": {
      "dependsOn": ["compile"],
      "executor": "@nx-tools/nx-container:build",
      "options": {
        "load": true,
        "quiet": true,
        "tags": ["ghcr.io/ecoma-io/app-site:latest"]
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "options": {
        "command": "INPUT_TAGS=ghcr.io/ecoma-io/alm-ingresstion:$VERSION npx nx build app-site --push"
      }
    }
  }
}
