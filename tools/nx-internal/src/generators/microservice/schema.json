{
  "$schema": "https://json-schema.org/schema",
  "$id": "Microservice",
  "title": "",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z\\-]+-service$",
      "description": "The name of the microservice (lowercase only, must end with '-service').",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "x-prompt": "What name would you like to use?"
    }
  },
  "required": ["name"]
}
